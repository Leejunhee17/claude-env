{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "claude-env",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:UTC}",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.1"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "runArgs": [
    // NET_ADMIN/NET_RAW: Dockerfile installs iptables/ipset/iproute2 for network isolation.
    // These capabilities are required for those packages to function.
    // If network-level sandboxing is removed in future, remove both these flags
    // AND the iptables/ipset/iproute2 packages from the Dockerfile together.
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "init": true,
  "updateRemoteUserUID": true,
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        },
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true
      }
    }
  },
  "remoteUser": "vscode",
  "mounts": [
    // bash history persisted in named volume across rebuilds
    "source=claude-env-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    // ~/.claude bind-mounted from host so auth token persists and OMC settings sync instantly.
    // NOTE: This is a trusted bidirectional channel — the container can write to host ~/.claude.
    // Security boundary is at Docker network/filesystem level, not at this mount.
    // ~/.ssh, ~/.aws, and other credential dirs are intentionally NOT mounted.
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    // gh CLI config persisted across rebuilds
    "source=claude-env-gh-${devcontainerId},target=/home/vscode/.config/gh,type=volume",
    // gitconfig from host (read-only — container cannot modify host git config)
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "GIT_CONFIG_GLOBAL": "/home/vscode/.gitconfig.local",
    "UV_LINK_MODE": "copy",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "LANG": "ko_KR.UTF-8",
    "LC_ALL": "ko_KR.UTF-8"
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY:}"
  },
  "initializeCommand": "test -f \"$HOME/.gitconfig\" || touch \"$HOME/.gitconfig\"",
  "workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace/claude-env",
  "postCreateCommand": "uv run --no-project /opt/post_install.py"
}
